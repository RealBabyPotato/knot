{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devPath": "http://127.0.0.1:1420",
    "distDir": "../dist"
  },
  "package": {
    "productName": "Knot",
    "version": "0.1.0"
  },
  "tauri": {
    "allowlist": {
      "all": false,
      "shell": {
        "all": false
      }
    },
    "bundle": {
      "active": false,
      "identifier": "com.knot.desktop"
    },
    "windows": [
      {
        "title": "Knot",
        "width": 1280,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ]
  }
}
